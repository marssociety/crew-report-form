{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/marssociety/crew-report-template/blob/main/report_schema.json",
  "title": "Crew Report Template",
  "description": "A standardized template for crew reports from analog Mars missions",
  "type": "object",
  "required": [
    "report_id",
    "title",
    "publish_date",
    "author",
    "station", 
    "mission_name",
    "crew_number",
    "mission_type",
    "mission_start_date",
    "mission_duration_day",
    "report_date",
    "report_type",
    "content"
  ],
  "properties": {
    "report_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for the report"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Title of the report"
    },
    "publish_date": {
      "type": "string",
      "format": "date-time",
      "description": "Date and time when the report was published"
    },
    "author": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Name of the report author"
    },
    "station": {
      "type": "string",
      "enum": ["MDRS", "FMARS", "HI-SEAS", "LUNARES"],
      "description": "Analog research station"
    },
    "mission_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Name or identifier of the mission"
    },
    "crew_number": {
      "type": "string",
      "pattern": "^[A-Z0-9-]+$",
      "description": "Crew designation number"
    },
    "mission_type": {
      "type": "string",
      "enum": ["Research", "Training", "Educational", "Engineering"],
      "description": "Type of mission being conducted"
    },
    "mission_start_date": {
      "type": "string",
      "format": "date-time",
      "description": "Start date and time of the mission"
    },
    "mission_duration_day": {
      "type": "integer",
      "minimum": 1,
      "maximum": 365,
      "description": "Duration of the mission in days"
    },
    "report_date": {
      "type": "string",
      "format": "date-time",
      "description": "Date and time this specific report covers"
    },
    "report_type": {
      "type": "string",
      "enum": ["Daily", "Weekly", "EVA", "Incident", "Final"],
      "description": "Type of report"
    },
    "content": {
      "type": "string",
      "minLength": 10,
      "description": "Main content of the report"
    },
    "eva_data": {
      "type": "object",
      "properties": {
        "eva_number": {
          "type": "integer",
          "minimum": 1
        },
        "participants": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "duration_minutes": {
          "type": "integer",
          "minimum": 1
        },
        "objectives": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "safety_notes": {
          "type": "string"
        }
      }
    },
    "crew_members": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": ["Commander", "Executive Officer", "Engineer", "Scientist", "Health & Safety Officer", "Journalist"]
          },
          "status": {
            "type": "string",
            "enum": ["Active", "Medical Leave", "Departed"]
          }
        },
        "required": ["name", "role", "status"]
      }
    },
    "resources": {
      "type": "object",
      "properties": {
        "water_usage_liters": {
          "type": "number",
          "minimum": 0
        },
        "power_usage_kwh": {
          "type": "number", 
          "minimum": 0
        },
        "food_consumption": {
          "type": "string"
        }
      }
    },
    "environmental_data": {
      "type": "object",
      "properties": {
        "temperature_celsius": {
          "type": "number"
        },
        "humidity_percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "pressure_kpa": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "incidents": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "incident_id": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["Medical", "Equipment Failure", "Safety", "Environmental"]
          },
          "severity": {
            "type": "string",
            "enum": ["Low", "Medium", "High", "Critical"]
          },
          "description": {
            "type": "string"
          },
          "resolution": {
            "type": "string"
          }
        },
        "required": ["incident_id", "type", "severity", "description"]
      }
    }
  }
}