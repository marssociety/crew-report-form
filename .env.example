# Backend Environment Variables
# Copy this file to backend/.env and fill in your values

NODE_ENV=production
PORT=3001

# Database (SQLite - file path)
# The database file will be created automatically at this location
DATABASE_PATH=./data/crew_reports.db

# CORS Settings (optional)
# ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Add any other backend-specific environment variables here
